# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# PENTING: Di VPS gunakan host "db" (nama service Docker), bukan "localhost"
DATABASE_URL=postgresql+asyncpg://sinoku:sinoku123@db:5432/sinoku_db

# Di local development (tanpa Docker) gunakan:
# DATABASE_URL=postgresql+asyncpg://sinoku:sinoku123@localhost:5432/sinoku_db

SECRET_KEY=ganti-dengan-secret-key-yang-kuat-minimal-32-karakter
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Origins yang diizinkan (JSON array)
# VPS:
CORS_ORIGINS=["http://103.181.184.169","https://yourdomain.com"]
# Local:
# CORS_ORIGINS=["http://localhost:5173"]
